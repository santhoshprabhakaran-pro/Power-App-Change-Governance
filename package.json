{
  "name": "change-governance-app",
  "private": true,
  "version": "2.0.0",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "husky || true",
    "deploy:app": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-app.ps1",
    "deploy:schema": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-schema.ps1 -Action export",
    "add-columns": "powershell -ExecutionPolicy Bypass -File ./scripts/add-columns.ps1",
    "regen": "pac modelbuilder build --outputDirectory ./src/generated"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@microsoft/applicationinsights-web": "3.4.3",
    "@microsoft/power-apps": "1.0.3",
    "@microsoft/teams-js": "^2.53.1",
    "@tanstack/react-virtual": "^3.14.6",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@microsoft/power-apps-vite": "1.0.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
