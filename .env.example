# Copy this file to .env.local and fill in the values
# Never commit .env.local to source control

# Application Insights connection string (get from Azure Portal)
# Example: InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://...
VITE_APPINSIGHTS_CS=

# Teams tenant ID (Azure AD tenant where the Teams app is registered)
VITE_TENANT_ID=

# Teams app content URL (Power Apps environment URL for the embedded app)
VITE_TEAMS_CONTENT_URL=

# Power Apps environment URL (Dataverse org URL)
VITE_ORG_URL=
